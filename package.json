{
  "name": "skala",
  "version": "1.0.0",
  "description": "Plataforma multimedia Skala",
  "main": "backend/server.js",
  "scripts": {
    "install:all": "npm install && npm --prefix backend install && npm --prefix frontend install",
    "dev": "concurrently \"npm --prefix backend run dev\" \"npm --prefix frontend run dev\"",
    "build:frontend": "npm --prefix frontend run build 2>&1",
    "build:all": "npm run build:frontend && node scripts/move-dist.js",
    "start": "node backend/server.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cloudinary": "^1.41.3",
    "lucide-react": "^1.9.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
